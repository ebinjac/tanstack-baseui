# AI Integration Environment Variables
# Copy the relevant vars into your .env file

# ─── Phase 1: OpenRouter (Active) ─────────────────────────────────────────
# Get your API key from https://openrouter.ai/keys
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Optional: used for OpenRouter's HTTP-Referer header (app identification)
APP_URL=http://localhost:3000

# ─── Phase 2: Org Internal Provider (Uncomment when ready) ─────────────────
# When switching: update src/lib/ai/provider.ts to use the org provider
# implementation (the commented-out template is already there).
#
# ORG_TOKEN_ENDPOINT=https://internal.corp
# ORG_GENAI_BASE_URL=https://internal.corp/api/genai/model
# ORG_CLIENT_ID=your_client_id
# ORG_CLIENT_SECRET=your_client_secret
# ORG_GENAI_MODEL=your-org-model-name
